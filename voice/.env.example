# CAPCOM voice bot config — copy to .env and edit.
# Every value has a sensible default in capcom_bot.py; override here only what you need.

# --- The mind: a loom `sonnet#capcom` seat (loom serve OpenAI shim) ---
# The seat holds the ksp-mcp tools + the CAPCOM persona. Point base_url at wherever
# your loom serve listens. If loom binds a mesh/LAN IP instead of loopback, use that,
# e.g.  CAPCOM_LLM_BASE_URL=http://<your-loom-host>:7791/v1
CAPCOM_LLM_BASE_URL=http://localhost:7791/v1
CAPCOM_LLM_MODEL=sonnet#capcom
CAPCOM_STICKY=sticky:capcom

# The shim is keyless on loopback but 401s a WRONG bearer. Either point at loom's
# token file (recommended) or paste the key directly.
CAPCOM_LLM_TOKEN_FILE=~/.stewards/loom-serve-token-current
# CAPCOM_LLM_API_KEY=not-needed

CAPCOM_LLM_TEMPERATURE=0.6

# --- Speech-to-text (faster-whisper, local) ---
# GPU: cuda / float16.  No GPU, or leaving the GPU to KSP: set cpu / int8.
CAPCOM_STT_DEVICE=cuda
CAPCOM_STT_COMPUTE=float16

# --- Text-to-speech (Kokoro, local) ---
# af_heart is the warm default. For a mission-control feel try a calm male controller
# voice: am_michael, am_adam (American) or bm_george (British).
CAPCOM_TTS_VOICE=af_heart

# --- Persona / greeting (optional) ---
# Leave PERSONA unset: the loom seat's CLAUDE.md IS the CAPCOM persona, so the bot
# sends only a one-line transport note. Only set this if you point the bot at a bare
# model with no prompt of its own.
# CAPCOM_PERSONA=
# CAPCOM_GREETING=

# --- Server ---
# host/port are runner CLI flags (see run-capcom.ps1), NOT env:
#   uv run capcom_bot.py --host localhost --port 7862
# localhost -> open http://localhost:7862 on the gaming PC (secure context, mic works).
# For a phone: bind --host 0.0.0.0 and reach it over TLS or a native WebRTC client —
# a browser blocks the mic on a plain-http non-localhost origin.
